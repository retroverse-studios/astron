{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ASTRON",
  "version": "0.1.0",
  "identifier": "studio.retroverse.astron",
  "build": {
    "beforeDevCommand": "pnpm --filter @astron/web dev",
    "devUrl": "http://localhost:5183",
    "beforeBuildCommand": "pnpm --filter @astron/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "ASTRON — The Clockwork of the Heavens, Charted",
        "width": 1240,
        "height": 880,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
