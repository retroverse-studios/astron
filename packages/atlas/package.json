{
  "name": "@astron/atlas",
  "version": "0.1.0",
  "description": "ASTRON atlas — offline city geocoding (GeoNames), historical timezone resolution, and Local Mean Time for pre-standard-time births.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./data/cities.tsv.gz": "./data/cities.tsv.gz"
  },
  "files": ["dist", "data"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:data": "tsx scripts/build-data.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "@types/node": "^22",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
